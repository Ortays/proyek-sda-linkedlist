{
    "rewrites": [
        {
            "source": "/img/(.*)",
            "destination": "/img/$1"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/index.html"
        }
    ]
}